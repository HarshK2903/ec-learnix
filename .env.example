# Server
PORT=5000
NODE_ENV=production

# MongoDB (use MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/docforge

# Redis (pick ONE approach)
# Option A — single URL (recommended for Upstash)
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_HOST.upstash.io:6379
# Option B — separate vars (Upstash)
# REDIS_HOST=YOUR_HOST.upstash.io
# REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=YOUR_UPSTASH_PASSWORD
# REDIS_TLS=true

# JWT (auto-generated on Render via render.yaml)
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AI Provider: "gemini" or "openai" or "groq"
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
GROQ_API_KEY=

# Client URL (set to your Render URL for CORS)
CLIENT_URL=https://docforge.onrender.com
